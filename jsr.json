{
	"$schema": "https://jsr.io/schema/config-file.v1.json",
	"name": "@kjanat/tree-sitter-recipe",
	"version": "0.3.1",
	"license": "MIT",
	"exports": {
		".": "./dist/index.js",
		"./grammar": "./dist/grammar.js",
		"./grammar/dutch": "./dist/grammar/dutch.js",
		"./grammar/latin": "./dist/grammar/latin.js",
		"./grammar/units": "./dist/grammar/units.js"
	},
	"publish": {
		"include": [
			"dist/**",
			"prebuilds/**",
			"queries/*",
			"test/**/*.recipe",
			"tree-sitter.json",
			"LICENSE",
			"README.md",
			"jsr.json",
			"package.json",
			"binding.gyp",
			"CHANGELOG.md"
		],
		"exclude": ["!dist", "!prebuilds"]
	}
}
