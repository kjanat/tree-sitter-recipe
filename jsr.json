{
	"$schema": "https://jsr.io/schema/config-file.v1.json",
	"name": "@kjanat/tree-sitter-recipe",
	"version": "0.1.0",
	"license": "MIT",
	"exports": {
		".": "./grammar.js",
		"./grammar.js": "./grammar.js",
		"./grammar/latin": "./grammar/latin/index.js",
		"./grammar/units": "./grammar/units/index.js"
	},
	"publish": {
		"include": [
			"grammar.js",
			"grammar/**/*.js",
			"queries/*.scm",
			"test/highlight/*.recipe",
			"tree-sitter.json",
			"LICENSE",
			"README.md",
			"jsr.json"
		]
	}
}
