{
	"$schema": "https://jsr.io/schema/config-file.v1.json",
	"name": "@kjanat/tree-sitter-recipe",
	"version": "0.1.0",
	"license": "MIT",
	"exports": {
		".": "./grammar.js",
		"./grammar.js": "./grammar.js",
		"./grammar/latin/compounding.js": "./grammar/latin/compounding.js",
		"./grammar/latin/conditional.js": "./grammar/latin/conditional.js",
		"./grammar/latin/dispensing.js": "./grammar/latin/dispensing.js",
		"./grammar/latin/forms.js": "./grammar/latin/forms.js",
		"./grammar/latin/frequency.js": "./grammar/latin/frequency.js",
		"./grammar/latin/index.js": "./grammar/latin/index.js",
		"./grammar/latin/route.js": "./grammar/latin/route.js",
		"./grammar/latin/timing.js": "./grammar/latin/timing.js",
		"./grammar/latin/warning.js": "./grammar/latin/warning.js",
		"./grammar/units/activity.js": "./grammar/units/activity.js",
		"./grammar/units/countable.js": "./grammar/units/countable.js",
		"./grammar/units/index.js": "./grammar/units/index.js",
		"./grammar/units/mass.js": "./grammar/units/mass.js",
		"./grammar/units/rate.js": "./grammar/units/rate.js",
		"./grammar/units/volume.js": "./grammar/units/volume.js"
	},
	"publish": {
		"include": [
			"grammar.js",
			"grammar/**/*.js",
			"queries/*.scm",
			"test/highlight/*.recipe",
			"tree-sitter.json",
			"LICENSE",
			"README.md",
			"jsr.json"
		]
	}
}
