{
	"$schema": "https://jsr.io/schema/config-file.v1.json",
	"name": "@kjanat/tree-sitter-recipe",
	"version": "0.1.0",
	"license": "MIT",
	"exports": {
		".": "./dist/index.js",
		"./grammar.js": "./dist/grammar.js",
		"./grammar/latin": "./dist/grammar/latin/index.js",
		"./grammar/units": "./dist/grammar/units/index.js"
	},
	"publish": {
		"include": [
			"dist/**",
			"queries/*",
			"test/**/*.recipe",
			"tree-sitter.json",
			"LICENSE",
			"README.md",
			"jsr.json",
			"package.json",
			"binding.gyp"
		],
		"exclude": ["!dist"]
	}
}
