{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true, "defaultBranch": "master" },
	"files": {
		"includes": ["./grammar.js", "./grammar/**/*.*{j,t}s", "./bindings/node/*.*{j,t}s", "./src/**"],
		"ignoreUnknown": true
	},
	"formatter": { "enabled": false },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": { "recommended": true },
			"correctness": { "recommended": true },
			"nursery": { "recommended": true },
			"security": { "recommended": true },
			"style": { "recommended": true },
			"suspicious": { "recommended": true }
		},
		"domains": {
			"project": "recommended",
			"test": "recommended",
			"types": "recommended"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"recommended": true,
				"organizeImports": "off"
			}
		}
	}
}
