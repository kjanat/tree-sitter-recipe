{
	"name": "tree-sitter-recipe",
	"version": "0.1.0",
	"description": "Pharmacological recipe notation",
	"keywords": [
		"incremental",
		"parsing",
		"tree-sitter",
		"recipe"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/tree-sitter-recipe.git"
	},
	"license": "MIT",
	"author": {
		"name": "Kaj Kowalski",
		"email": "info@kajkowalski.nl",
		"url": "https://github.com/kjanat"
	},
	"type": "module",
	"imports": {
		"#grammar": "./grammar.js",
		"#grammar/*": "./grammar/*",
		"#grammar/latin": "./grammar/latin/index.js",
		"#grammar/units": "./grammar/units/index.js"
	},
	"exports": {
		".": "./dist/index.js",
		"./grammar": {
			"types": "./dist/grammar.d.ts",
			"default": "./dist/grammar.js"
		},
		"./grammar/latin": "./dist/grammar/latin.js",
		"./grammar/units": "./dist/grammar/units.js",
		"./package.json": "./package.json",
		"./grammar/*": "./dist/grammar/*",
		"./binding.gyp": "./binding.gyp",
		"./queries/*": "./queries/*",
		"./test/{highlight,fixtures}/*.recipe": "./test/{highlight,fixtures}/*.recipe",
		"./tree-sitter-recipe.wasm": "./tree-sitter-recipe.wasm",
		"./tree-sitter.json": "./tree-sitter.json",
		"./src/*": "./src/*"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"*.wasm",
		"binding.gyp",
		"bindings/node",
		"dist",
		"jsr.json",
		"prebuilds",
		"queries",
		"scripts",
		"src",
		"test/**/*.recipe",
		"tree-sitter.json",
		"!**/*.o"
	],
	"scripts": {
		"bd": "bun run build",
		"build": "tsdown",
		"check": "biome check",
		"fmt": "dprint fmt",
		"generate": "tree-sitter generate; dprint fmt",
		"highlight": "tree-sitter highlight",
		"postinstall": "node scripts/ensure-native.mjs",
		"lint": "biome lint",
		"prepack": "bun run build",
		"prestart": "tree-sitter build --wasm",
		"start": "tree-sitter playground",
		"test": "node --test bindings/node/*_test.js",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"node-addon-api": "^8.5.0",
		"node-gyp-build": "^4.8.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/bun": "^1.3.12",
		"dprint": "^0.54.0",
		"prebuildify": "^6.0.1",
		"tree-sitter": "^0.25.0",
		"tree-sitter-cli": "^0.26.8",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"tree-sitter": "^0.25.0"
	},
	"peerDependenciesMeta": {
		"tree-sitter": {
			"optional": true
		}
	},
	"packageManager": "bun@1.3.13",
	"volta": {
		"node": "25.9.0",
		"npm": "11.13.0"
	},
	"patchedDependencies": {
		"tree-sitter@0.25.0": "patches/tree-sitter@0.25.0.patch"
	}
}
