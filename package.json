{
	"name": "tree-sitter-recipe",
	"version": "0.1.0",
	"description": "Pharmacological recipe notation",
	"keywords": [
		"incremental",
		"parsing",
		"tree-sitter",
		"recipe"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/tree-sitter-recipe.git"
	},
	"funding": "https://none",
	"license": "MIT",
	"author": {
		"name": "Kaj Kowalski",
		"email": "info@kajkowalski.nl",
		"url": "https://github.com/kjanat"
	},
	"type": "module",
	"exports": {
		".": {
			"default": "./bindings/node"
		},
		"./grammar.js": "./grammar.js",
		"./grammar/*": "./grammar/*",
		"./queries/*": "./queries/*",
		"./test/fixtures/*": "./test/fixtures/*",
		"./test/highlight/*": "./test/highlight/*",
		"./package.json": "./package.json",
		"./binding.gyp": "./binding.gyp"
	},
	"main": "bindings/node",
	"module": "bindings/node",
	"types": "bindings/node",
	"files": [
		"grammar.js",
		"grammar/**",
		"tree-sitter.json",
		"binding.gyp",
		"prebuilds/**",
		"bindings/node/*",
		"queries/*",
		"src/**",
		"test/fixtures/**",
		"test/highlight/**",
		"*.wasm"
	],
	"scripts": {
		"generate": "tree-sitter generate; dprint fmt",
		"highlight": "tree-sitter highlight",
		"postinstall": "node-gyp-build",
		"prestart": "tree-sitter build --wasm",
		"start": "tree-sitter playground",
		"test": "node --test bindings/node/*_test.js"
	},
	"dependencies": {
		"node-addon-api": "^8.5.0",
		"node-gyp-build": "^4.8.4"
	},
	"devDependencies": {
		"@types/bun": "^1.3.12",
		"dprint": "^0.54.0",
		"prebuildify": "^6.0.1",
		"tree-sitter": "^0.25.0",
		"tree-sitter-cli": "^0.26.8",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"tree-sitter": "^0.25.0"
	},
	"peerDependenciesMeta": {
		"tree-sitter": {
			"optional": true
		}
	},
	"packageManager": "bun@1.3.13",
	"volta": {
		"node": "22.22.2",
		"npm": "11.12.1"
	}
}
