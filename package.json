{
	"name": "tree-sitter-recipe",
	"version": "0.1.0",
	"description": "Pharmacological recipe notation",
	"keywords": ["incremental", "parsing", "tree-sitter", "recipe"],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/tree-sitter-recipe.git"
	},
	"license": "MIT",
	"author": {
		"name": "Kaj Kowalski",
		"email": "info@kajkowalski.nl",
		"url": "https://github.com/kjanat"
	},
	"type": "module",
	"imports": {
		"#grammar": "./grammar.js",
		"#grammar/*": "./grammar/*",
		"#grammar/dutch": "./grammar/dutch/index.js",
		"#grammar/latin": "./grammar/latin/index.js",
		"#grammar/units": "./grammar/units/index.js",
		"#plugin/jsr-ts-self-types": "./plugins/jsr-ts-self-types.ts",
		"#pkg": "./package.json",
		"#src/*": "./src/*",
		"#ts": "./tree-sitter.json"
	},
	"exports": {
		".": "./dist/index.js",
		"./grammar": {
			"types": "./dist/grammar.d.ts",
			"default": "./dist/grammar.js"
		},
		"./grammar/dutch": "./dist/grammar/dutch.js",
		"./grammar/latin": "./dist/grammar/latin.js",
		"./grammar/units": "./dist/grammar/units.js",
		"./package.json": "./package.json",
		"./grammar/*": "./dist/grammar/*",
		"./binding.gyp": "./binding.gyp",
		"./queries/*": "./queries/*",
		"./test/{highlight,fixtures}/*.recipe": "./test/{highlight,fixtures}/*.recipe",
		"./tree-sitter-recipe.wasm": "./tree-sitter-recipe.wasm",
		"./tree-sitter.json": "./tree-sitter.json",
		"./src/*": "./src/*"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"*.wasm",
		"/binding.gyp",
		"/bindings/node",
		"/dist",
		"/jsr.json",
		"/prebuilds",
		"/queries",
		"/scripts",
		"/src",
		"/test/**/*.recipe",
		"/tree-sitter.json",
		"!**/*.o"
	],
	"scripts": {
		"bd": "bun run build",
		"build": "tsdown",
		"check": "biome check",
		"fmt": "dprint fmt",
		"generate": "tree-sitter generate; dprint fmt",
		"highlight": "tree-sitter highlight",
		"postinstall": "node scripts/ensure-native.ts",
		"lint": "biome lint",
		"prepack": "bun run build",
		"prestart": "tree-sitter build --wasm",
		"start": "tree-sitter playground",
		"test": "node --test bindings/node/*_test.js",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"node-addon-api": "^8.8",
		"node-gyp-build": "^4.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5",
		"@types/bun": "^1.3",
		"dprint": "^0.54",
		"prebuildify": "^6",
		"tree-sitter": "^0.25",
		"tree-sitter-cli": "^0.26",
		"tsdown": "^0.22",
		"typescript": "^6"
	},
	"peerDependencies": {
		"tree-sitter": "^0.25"
	},
	"peerDependenciesMeta": {
		"tree-sitter": {
			"optional": true
		}
	},
	"packageManager": "bun@1.3.14",
	"volta": {
		"node": "26.4.0",
		"npm": "11.17.0"
	},
	"patchedDependencies": {
		"tree-sitter@0.25.0": "patches/tree-sitter@0.25.0.patch"
	}
}
